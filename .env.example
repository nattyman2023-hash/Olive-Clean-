# Local API / production Node app
PORT=4000
DB_DRIVER=sqlite
DB_FILE=./data/olive.sqlite
JWT_SECRET=replace-with-a-long-random-secret
UPLOAD_DIR=./uploads

# Set DB_DRIVER=mysql on Hostinger
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_NAME=hostinger_database_name
# DB_USER=hostinger_database_user
# DB_PASSWORD=hostinger_database_password

